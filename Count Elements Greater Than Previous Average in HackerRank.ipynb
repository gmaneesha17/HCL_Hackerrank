    "def count(a):\n",
    "    n=len(a)\n",
    "    s=a[0]\n",
    "    c=0\n",
    "    avg=0\n",
    "    for i in range(1,n):\n",
    "        avg=s/i\n",
    "        if a[i]>avg:\n",
    "            c+=1\n",
    "        s=s+a[i]\n",
    "    return c\n",
    "a=list(map(int,input().split()))\n",
    "print(count(a))"
   ]
