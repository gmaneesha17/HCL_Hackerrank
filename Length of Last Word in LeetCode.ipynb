   "source": [
    "def lenlast(s):\n",
    "    i=len(s)-1\n",
    "    while i>=0 and s[i]==\" \":\n",
    "        i-=1\n",
    "    c=0\n",
    "    while i>=0 and s[i]!=\" \":\n",
    "        c+=1\n",
    "        i-=1\n",
    "    return c\n",
    "s=input()\n",
    "print(lenlast(s))"
   ]
