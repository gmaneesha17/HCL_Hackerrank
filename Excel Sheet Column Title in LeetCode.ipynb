   "source": [
    "def convert(n):\n",
    "    r=\"\"\n",
    "    while n>0:\n",
    "        n=n-1\n",
    "        ch=chr((n%26)+ord('A'))\n",
    "        r=ch+r\n",
    "        n=n//26\n",
    "    return r\n",
    "n=int(input())\n",
    "print(convert(n))"
   ]
