   "source": [
    "def lis(a):\n",
    "    n=len(a)\n",
    "    dp=[1]*n\n",
    "    for i in range(n):\n",
    "        for j in range(i):\n",
    "            if a[j]<a[i]:\n",
    "                dp[i]=max(dp[i],dp[j]+1)\n",
    "    return max(dp)\n",
    "a=list(map(int,input().split()))\n",
    "print(lis(a))"
   ]
