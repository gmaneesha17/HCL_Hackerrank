   "source": [
    "def mop(a):\n",
    "    prev=0\n",
    "    c=0\n",
    "    for x in a:\n",
    "        if x>0 and x!=prev:\n",
    "            c+=1\n",
    "            prev=x\n",
    "    return c\n",
    "a=list(map(int,input().split()))\n",
    "print(mop(a))"
   ]
