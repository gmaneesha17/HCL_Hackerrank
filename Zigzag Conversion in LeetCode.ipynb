   "source": [
    "def zzag(s,r):\n",
    "    rows=[\"\"]*r\n",
    "    cr=0\n",
    "    gd=False\n",
    "    for ch in s:\n",
    "        rows[cr]+=ch\n",
    "        if cr==0 or cr==r-1:\n",
    "            gd=not gd\n",
    "        if gd:\n",
    "            cr+=1\n",
    "        else:\n",
    "            cr-=1\n",
    "    return \"\".join(rows)\n",
    "s=input()\n",
    "r=int(input())\n",
    "print(zzag(s,r))"
   ]
  },
