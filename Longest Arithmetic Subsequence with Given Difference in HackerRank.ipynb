   "source": [
    "def lcswgd(a,d):\n",
    "    ml=0\n",
    "    dp={}\n",
    "    for x in a:\n",
    "        prev=x-d\n",
    "        if prev in dp:\n",
    "            dp[x]=dp[prev]+1\n",
    "        else:\n",
    "            dp[x]=1\n",
    "        ml=max(ml,dp[x])\n",
    "    return ml\n",
    "a=list(map(int,input().split()))\n",
    "d=int(input())\n",
    "print(lcswgd(a,d))"
   ]
  },
