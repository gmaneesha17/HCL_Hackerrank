   "source": [
    "def remove_k(a,k):\n",
    "    st=[]\n",
    "    for n in a:\n",
    "        while st and st[-1]>n and k>0:\n",
    "            st.pop()\n",
    "            k-=1\n",
    "        st.append(n)\n",
    "    return st\n",
    "a=list(map(int,input().split()))\n",
    "k=int(input())\n",
    "print(remove_k(a,k))"
   ]
  },
