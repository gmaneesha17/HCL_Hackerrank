   "source": [
    "def mprofit(prices):\n",
    "    minprice=prices[0]\n",
    "    maxp=0\n",
    "    for p in prices:\n",
    "        if p<minprice:\n",
    "            minprice=p\n",
    "        profit=p-minprice\n",
    "        if profit>maxp:\n",
    "            maxp=profit\n",
    "    return maxp\n",
    "a=list(map(int,input().split()))\n",
    "print(mprofit(a))"
   ]
