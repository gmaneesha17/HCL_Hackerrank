    "def lus(s):\n",
    "    seen=set()\n",
    "    l=0\n",
    "    ml=0\n",
    "    for r in range(len(s)):\n",
    "        while s[r] in seen:\n",
    "            seen.remove(s[l])\n",
    "            l+=1\n",
    "        seen.add(s[r])\n",
    "        ml=max(ml,r-l+1)\n",
    "    return ml\n",
    "s=input()\n",
    "print(lus(s))"
   ]
