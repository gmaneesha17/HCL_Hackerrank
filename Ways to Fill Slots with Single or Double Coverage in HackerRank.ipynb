    "def ways(n):\n",
    "    if n==0 or n==1:\n",
    "        return 1\n",
    "    a,b=1,1\n",
    "    for i in range(2,n+1):\n",
    "        a,b=b,a+b\n",
    "    return b\n",
    "n=int(input())\n",
    "print(ways(n))"
   ]
