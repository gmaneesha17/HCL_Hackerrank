   "source": [
    "def fibonacciModified(t1, t2, n):\n",
    "    for i in range(3, n + 1):\n",
    "        t1, t2 = t2, t1 + t2 * t2\n",
    "    return t2\n",
    "t1, t2, n = map(int, input().split())\n",
    "print(fibonacciModified(t1, t2, n))"
   ]
