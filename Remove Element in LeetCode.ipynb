    "def remele(a,v):\n",
    "    k=0\n",
    "    for i in range(len(a)):\n",
    "        if a[i]!=v:\n",
    "            a[k]=a[i]\n",
    "            k+=1\n",
    "    return k\n",
    "a=list(map(int,input().split()))\n",
    "v=int(input())\n",
    "print(remele(a,v))\n",
    "i=remele(a,v)\n",
    "for k in range(i-1):\n",
    "    print(a[k],end=\" \")"
   ]
