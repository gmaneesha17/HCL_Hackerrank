    "def first_missing(a):\n",
    "    n=len(a)\n",
    "    for i in range(n):\n",
    "        while i<=a[i]<=n and a[a[i]-1]!=a[i]:\n",
    "            a[a[i]-1],a[i]=a[i],a[a[i]-1]\n",
    "    for i in range(n):\n",
    "        if a[i]!=i+1:\n",
    "            return i+1\n",
    "    return n+1\n",
    "a=list(map(int,input().split()))\n",
    "print(first_missing(a))"
   ]
