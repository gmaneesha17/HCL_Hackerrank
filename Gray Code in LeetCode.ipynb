   "source": [
    "def gray(n):\n",
    "    res=[]\n",
    "    for i in range(1<<n):\n",
    "        res.append(i^(i>>1))\n",
    "    return res\n",
    "n=int(input())\n",
    "print(gray(n))"
   ]
