   "source": [
    "def peak(a):\n",
    "    l=0\n",
    "    h=len(a)-1\n",
    "    while l<h:\n",
    "        m=(l+h)//2\n",
    "        if a[m]<a[m+1]:\n",
    "            l=m+1\n",
    "        else:\n",
    "            h=m\n",
    "    return a[l]\n",
    "a=list(map(int,input().split()))\n",
    "print(peak(a))"
   ]
